# ── Database ──────────────────────────────────────────
DATABASE_URL="mysql://root:MYSQLTEST@localhost:3306/seva_bridge"

# ── JWT Auth ──────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── File Uploads ──────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
