// Seva-Bridge Prisma Schema
// Database: MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  VOLUNTEER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  WALLET
}

enum ServiceCategory {
  VITALS_MONITORING     // Level 1
  WOUND_CARE            // Level 2
  MEDICATION_MANAGEMENT // Level 3
  ADVANCED_CARE         // Level 4
}

enum SkillLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(PATIENT)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient   Patient?
  volunteer Volunteer?

  @@map("users")
}

model Patient {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address          String?
  dateOfBirth      DateTime?
  emergencyContact String?
  latitude         Float?
  longitude        Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings Booking[]

  @@map("patients")
}

model Volunteer {
  id               String     @id @default(uuid())
  userId           String     @unique
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualification    String?
  yearOfStudy      Int?
  certificationUrl String?
  rating           Float      @default(0)
  ratingCount      Int        @default(0)
  skillLevel       SkillLevel @default(LEVEL_1)
  isVerified       Boolean    @default(false)
  isOnline         Boolean    @default(false)
  latitude         Float?
  longitude        Float?
  totalEarnings    Float      @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  bookings Booking[]

  @@map("volunteers")
}

model Service {
  id          String          @id @default(uuid())
  name        String
  description String?
  category    ServiceCategory
  basePrice   Float
  requiredLevel SkillLevel    @default(LEVEL_1)
  icon        String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  bookings Booking[]

  @@map("services")
}

model Booking {
  id             String        @id @default(uuid())
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id])
  volunteerId    String?
  volunteer      Volunteer?    @relation(fields: [volunteerId], references: [id])
  serviceId      String
  service        Service       @relation(fields: [serviceId], references: [id])
  status         BookingStatus @default(PENDING)
  scheduledTime  DateTime?
  totalAmount    Float         @default(0)
  distanceKm     Float?
  patientLat     Float?
  patientLng     Float?
  volunteerLat   Float?
  volunteerLng   Float?
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  healthReport HealthReport?
  payment      Payment?

  @@map("bookings")
}

model HealthReport {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  vitalsData Json?
  notes      String?  @db.Text
  fileUrls   Json?    // Array of uploaded file URLs
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("health_reports")
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  transactionId String?       @unique
  status        PaymentStatus @default(PENDING)
  amount        Float
  mode          PaymentMode   @default(CASH)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@map("payments")
}
